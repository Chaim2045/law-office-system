# Required for @firebase/rules-unit-testing@3.0.4 peer dep mismatch:
# It declares peer firebase@^10 but functions correctly with firebase@9.23.0
# (it only uses firebase types + the emulator HTTP API).
#
# Added Pre-H.0.0.D 2026-05-29. Remove this flag when root firebase is
# upgraded to v10+ (likely via dependabot PR-251 or a planned migration).
legacy-peer-deps=true
