rules_version = '2';

/**
 * ════════════════════════════════════════════════════════════════════════════
 * FIREBASE STORAGE SECURITY RULES
 * ════════════════════════════════════════════════════════════════════════════
 *
 * Last Updated: 2026-06-16
 * Purpose: Secure storage for fee agreements (PDF/Images) on clients/ AND cases/
 *
 * NOTE: signed agreement objects are accessed via short-lived signed URLs minted
 * by the admin-gated `getFeeAgreementUrl` Cloud Function (Admin SDK signs,
 * bypassing these rules by design). These rules are the defense-in-depth backstop
 * for any direct client-SDK access — the actual access control is admin-gated CF +
 * private object ACLs (the legacy public ACLs are revoked by a one-time migration).
 *
 * ════════════════════════════════════════════════════════════════════════════
 */

service firebase.storage {
  match /b/{bucket}/o {

    // ==================== Helper Functions ====================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is admin (Custom Claims)
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.role == 'admin';
    }

    // Validate file size (max 10MB)
    function isValidFileSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Validate file type (PDF or Images only)
    function isValidFileType() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('image/jpeg') ||
             request.resource.contentType.matches('image/png') ||
             request.resource.contentType.matches('image/webp');
    }

    // ==================== Storage Rules ====================

    // Client Fee Agreements
    // Path: /clients/{clientId}/agreements/{fileName}
    match /clients/{clientId}/agreements/{fileName} {
      // Read: Admin only
      allow read: if isAdmin();

      // Write: Admin only + file validation
      allow write: if isAdmin() &&
                      isValidFileSize() &&
                      isValidFileType();

      // Delete: Admin only
      allow delete: if isAdmin();
    }

    // Case Fee Agreements
    // Path: /cases/{caseId}/agreements/{fileName}
    // Added 2026-06-16 (security remediation) — the WhatsApp upload path writes
    // agreements to cases/ as well as clients/ (WhatsAppBot.js entityType==='case').
    // Mirrors the clients/ block above so the cases/ path expresses admin-only
    // intent explicitly instead of relying on the catch-all default-deny.
    match /cases/{caseId}/agreements/{fileName} {
      // Read: Admin only
      allow read: if isAdmin();

      // Write: Admin only + file validation
      allow write: if isAdmin() &&
                      isValidFileSize() &&
                      isValidFileType();

      // Delete: Admin only
      allow delete: if isAdmin();
    }

    // Default: Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
