{
  "name": "law-office-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for Law Office Management System",
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ts": "jest --selectProjects src-ts --verbose",
    "test:legacy": "jest --selectProjects legacy-js --verbose",
    "build:ts": "tsc --project src-ts/tsconfig.json",
    "typecheck:ts": "tsc --project src-ts/tsconfig.json --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@hebcal/core": "^3.50.4",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "joi": "^17.11.0",
    "twilio": "^5.3.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "private": true
}
